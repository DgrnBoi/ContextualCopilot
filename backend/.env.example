# GitHub personal access token for higher rate limits (unauthenticated = 60 req/hr)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenRouter or Anthropic API key for real AI responses (leave blank for demo mode)
# OpenRouter: https://openrouter.ai/keys  (prefix: sk-or-...)
# Anthropic:  https://console.anthropic.com/ (prefix: sk-ant-...)
ANTHROPIC_API_KEY=your_api_key_here
